# ============================================
# 普瑞赛斯 (Priestes) 桌宠 — 环境变量配置
# ============================================
# 复制此文件为 .env 并填入你的真实配置
# cp .env.example .env
# ============================================

# ─── AI API 配置（必填） ───
# 支持所有兼容 OpenAI API 格式的服务商
# 推荐使用 DeepSeek（国内访问快，性价比高）

# API 基础地址（必须以 /v1 结尾）
API_BASE_URL=https://api.deepseek.com/v1

# API 密钥
# DeepSeek: 在 https://platform.deepseek.com/api_keys 获取
# OpenAI:  在 https://platform.openai.com/api-keys 获取
API_KEY=sk-your-api-key-here

# 模型名称
# DeepSeek: deepseek-chat
# OpenAI:   gpt-4o 或 gpt-4o-mini
API_MODEL=deepseek-chat

# ─── 数据库配置（开发模式可选） ───
# 仅 Next.js 开发模式使用 Prisma + SQLite
# 桌面部署版使用 JSON 文件存储，无需数据库
DATABASE_URL=file:./db/custom.db

# ─── 网易云音乐 API（可选） ───
# 如果部署了 NeteaseCloudMusicApi，填写地址以启用网易云搜索
# NETSEASE_API_URL=http://localhost:3000
