{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Priestes",
  "version": "1.0.0",
  "identifier": "com.priestes.desktop",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npx next dev --webpack -p 3000",
    "beforeBuildCommand": "node scripts/tauri-prebuild.js"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Priestes",
        "width": 1280,
        "height": 800,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": true,
        "shadow": false,
        "fullscreen": false,
        "maximized": true,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: https: blob:; media-src 'self' https: blob:; connect-src 'self' https: http://localhost:*; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "resources": [],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "languages": ["SimpChinese", "English"],
        "displayLanguageSelector": true
      }
    }
  }
}
